#!/usr/bin/env bash
set -e

echo "Running pre-push hook..."

if [ -n "$(git status --porcelain)" ]; then
  echo "Error: You have uncommitted changes. Please commit, stash, or drop them before pushing."
  exit 1
fi

echo "1. Checking rust formatting..."
cargo fmt --all -- --check

echo "2. Running rust clippy (--all-targets, mirroring the CI gate)..."
cargo clippy --workspace --all-targets -- -D warnings

echo "3. Checking rustdoc (the CI gate's doc step: -D warnings)..."
RUSTDOCFLAGS="-D warnings" cargo doc --workspace --no-deps

echo "4. Running rust tests..."
cargo test --workspace

echo "4b. Gate parity (oracle integrity, conformance ledger, anti-hardcode)..."
cargo run -q -p xtask -- oracle-verify
cargo run -q -p xtask -- report
./scripts/anti-hardcode.sh

echo "5. Running structural witnesses..."
cargo test --release -p hologram-ai-conformance --features=structural \
    --test structural_ce \
    --test structural_za \
    --test structural_zm \
    --test structural_cf \
    --test structural_lw \
    --test structural_im

echo "6. Checking wasm32-unknown-unknown compilation..."
cargo build --target wasm32-unknown-unknown -p hologram-ai-quant
cargo build --target wasm32-unknown-unknown -p hologram-ai-tokenizer --no-default-features

echo "7. Checking thumbv7em-none-eabi compilation..."
cargo build --target thumbv7em-none-eabi -p hologram-ai-quant
cargo build --target thumbv7em-none-eabi -p hologram-ai-tokenizer --no-default-features

echo "8. Running ORT conformance tests..."
cargo test --release -p hologram-ai-conformance --features=conformance

echo "9. Building web app..."
cd apps/web
pnpm install
pnpm run build

echo "10. Running web app tests..."
pnpm run test

SKIPPED=""

echo "11. Browser decode kernels in-wasm (wasm-pack test --node — the real κ119/κ120 kernels)..."
# The blind spot that let the v0.9.0 `unreachable` trap ship: `cargo check`
# proved the wasm binding builds; nothing RAN its decode kernels. Guarded so a
# machine without wasm-pack still pushes (CI runs it authoritatively).
if command -v wasm-pack >/dev/null 2>&1; then
    wasm-pack test --node crates/hologram-ai-wasm
else
    echo "   (skipped: wasm-pack is not installed)"
    SKIPPED="$SKIPPED wasm-decode-kernels"
fi

echo "12. Browser BDD (the CI/Deploy journey gate: hermetic download→compile→run→handshake)..."
# Rust changes reach the browser only through the wasm binding, so rebuild it
# before driving the journey — this is exactly what caught a residency
# regression the vitest suite could not see. Guarded so a machine without
# wasm-pack or the Playwright browser still pushes (CI runs it authoritatively).
if command -v wasm-pack >/dev/null 2>&1 && ls "$HOME/.cache/ms-playwright"/chromium-* >/dev/null 2>&1; then
    pnpm run wasm
    pnpm run bdd
else
    echo "   (skipped: wasm-pack or the Playwright Chromium is not installed)"
    SKIPPED="$SKIPPED browser-journey"
fi

if [ -n "$SKIPPED" ]; then
    echo ""
    echo "Pre-push checks passed — but these gates were SKIPPED locally and are NOT verified:$SKIPPED"
    echo "CI runs them authoritatively and WILL block the merge if they fail. Do not treat this push as green."
else
    echo "Pre-push checks passed successfully (browser gates included)!"
fi
