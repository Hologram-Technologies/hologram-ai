{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hologram-ai-desktop",
  "version": "0.1.0",
  "identifier": "ai.hologram.chat",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hologram chat",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/hologram-ai"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
