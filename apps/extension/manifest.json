{
  "manifest_version": 3,
  "name": "Holospaces Egress Extension",
  "version": "1.0.0",
  "description": "Injects Hugging Face auth for model downloads.",
  "permissions": [
    "declarativeNetRequest",
    "cookies"
  ],
  "host_permissions": [
    "*://huggingface.co/*",
    "*://*.github.io/*",
    "*://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.github.io/*", "*://localhost/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
