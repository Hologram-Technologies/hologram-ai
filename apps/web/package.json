{
  "name": "hologram-ai-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "hologram-ai browser GUI (WebAssembly, GitHub Pages). See specs/docs/adrs/0017-hologram-ai-web-wasm.md",
  "scripts": {
    "wasm": "wasm-pack build ../../crates/hologram-ai-wasm --target web --out-dir ../../apps/web/src/wasm --release",
    "wasm:threads": "bash scripts/build-wasm-threads.sh",
    "wasm:all": "pnpm wasm && pnpm wasm:threads",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run --browser.headless",
    "preview": "vite preview",
    "bdd": "pnpm build && cucumber-js --config bdd/cucumber.mjs",
    "bdd:live": "pnpm build && cucumber-js --config bdd/cucumber.mjs --profile live",
    "bdd:threads": "pnpm build && node bdd/probe-pool-registration.mjs && node bdd/probe-threads-local.mjs",
    "bdd:threads:live": "pnpm build && node bdd/probe-threads-live.mjs && node bdd/probe-threads-teardown.mjs",
    "bench:pool": "bash scripts/bench-pool-scaling.sh"
  },
  "dependencies": {
    "@huggingface/jinja": "^0.5.9",
    "katex": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/browser": "^2.1.9",
    "playwright": "^1.61.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}